{
  "server": true,
  "bootstrap_expect": 1,
  "ui_config": {
    "enabled": true
  },
  "client_addr": "0.0.0.0",
  "data_dir": "/consul/data",
  "log_level": "DEBUG",
  "enable_local_script_checks": true,
  "telemetry": {
    "prometheus_retention_time": "60s"
  },
  "ports": {
    "dns": 53
  },
  "dns_config": {
    "allow_stale": false,
    "service_ttl": {"*": "0s"}
  }
}
