{
  "description": "PostgreSQL metrics during failover: replication lag, connections, transactions, WAL, checkpoints",
  "editable": true,
  "panels": [
    {
      "title": "Replication Lag (bytes)",
      "description": "Bytes of WAL the replica is behind the primary",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prb-prometheus" },
      "targets": [
        {
          "expr": "pg_replication_lag{job=\"postgres\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prb-prometheus" },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres\"}",
          "legendFormat": "{{instance}} ({{state}})"
        }
      ]
    },
    {
      "title": "Transactions per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prb-prometheus" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{job=\"postgres\", datname=\"bench\"}[$__rate_interval])",
          "legendFormat": "{{instance}} commits/s"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{job=\"postgres\", datname=\"bench\"}[$__rate_interval])",
          "legendFormat": "{{instance}} rollbacks/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "WAL Generation Rate",
      "description": "Rate of WAL bytes generated — spikes during promotion/catchup",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prb-prometheus" },
      "targets": [
        {
          "expr": "rate(pg_stat_wal_wal_bytes_total{job=\"postgres\"}[$__rate_interval])",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "title": "Checkpoint Duration",
      "description": "Time spent in checkpoints — relevant after promotion",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prb-prometheus" },
      "targets": [
        {
          "expr": "rate(pg_stat_bgwriter_checkpoint_write_time{job=\"postgres\"}[$__rate_interval])",
          "legendFormat": "{{instance}} write_time"
        },
        {
          "expr": "rate(pg_stat_bgwriter_checkpoint_sync_time{job=\"postgres\"}[$__rate_interval])",
          "legendFormat": "{{instance}} sync_time"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Database Up/Down",
      "description": "1 = up, 0 = down — shows exact moment of PG availability",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prb-prometheus" },
      "targets": [
        {
          "expr": "pg_up{job=\"postgres\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 1 }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["patroni", "postgresql", "database"],
  "time": { "from": "now-30m", "to": "now" },
  "title": "PostgreSQL Metrics",
  "uid": "prb-postgres-metrics",
  "version": 1
}
