###############################################################################
# patroni-routing-bench — Measurement Tool Configuration
#
# Copy this file to .env and fill in your Patroni cluster endpoints.
#
# Quick start:
#   cp .env.example .env
#   vim .env                                    # fill in your endpoints
#   docker compose up -d                        # start observers + TimescaleDB
#   docker compose --profile failover up -d     # start heartbeat client
#   ssh user@leader "sudo systemctl stop patroni"  # inject failure
#   docker compose --profile charts run --rm charts # generate report
###############################################################################

# ── Your Patroni Nodes ──────────────────────────────────────────────
# Format: name1:http://ip1:port,name2:http://ip2:port,name3:http://ip3:port
# The observer polls each node's REST API to detect role changes.
PATRONI_TARGETS=node1:http://10.0.1.11:8008,node2:http://10.0.1.12:8008,node3:http://10.0.1.13:8008

# ── Direct PostgreSQL Connections (for postgres observer) ──────────
# Format: name1:host=ip1 port=5432 dbname=postgres user=postgres password=xxx,...
# These connect DIRECTLY to each node, NOT through the routing layer.
# The observer detects promotion and connection availability per node.
PG_TARGETS=node1:host=10.0.1.11 port=5432 dbname=postgres user=postgres password=your_password,node2:host=10.0.1.12 port=5432 dbname=postgres user=postgres password=your_password,node3:host=10.0.1.13 port=5432 dbname=postgres user=postgres password=your_password

# ── Your Consul Server ──────────────────────────────────────────────
# The observer watches the Consul KV leader key using blocking queries.
CONSUL_URL=http://10.0.1.20:8500
CONSUL_SCOPE=your-cluster-name

# ── Your PostgreSQL Connection (through routing layer) ──────────────
# This is where the heartbeat CLIENT connects — through HAProxy, VIP,
# DNS, or direct. This measures client-perceived downtime.
PG_CONNSTRING=host=10.0.1.100 port=5432 dbname=postgres user=postgres password=your_password connect_timeout=5

# ── HAProxy Stats (optional) ────────────────────────────────────────
# Uncomment if your routing layer is HAProxy. The observer polls the
# stats endpoint to detect backend UP/DOWN transitions.
# HAPROXY_STATS_URL=http://10.0.1.100:8404/stats;csv

# ── Label for this measurement ──────────────────────────────────────
# Used to group events in TimescaleDB. Example: "prod-haproxy", "staging-vip"
COMBINATION_ID=my-cluster

# ── Observer Settings ───────────────────────────────────────────────
# POLL_INTERVAL_MS=100        # Observer polling interval (default: 100ms)
# HEARTBEAT_INTERVAL_MS=100   # Client query interval (default: 100ms)

# ── TimescaleDB Settings ───────────────────────────────────────────
# Only change these if you use an external TimescaleDB instance.
# TSDB_PORT=5433
# TSDB_USER=bench
# TSDB_PASSWORD=bench
# TSDB_DB=bench
