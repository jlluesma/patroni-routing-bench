# Generated by Terraform (terraform apply writes ansible/inventory/gcp.ini).
# This file is a template — actual IPs come from Terraform outputs.
# Copy to gcp.ini and fill in external IPs if managing manually.

[patroni]
patroni-1 ansible_host=EXTERNAL_IP_1 internal_ip=10.0.1.10
patroni-2 ansible_host=EXTERNAL_IP_2 internal_ip=10.0.1.11
patroni-3 ansible_host=EXTERNAL_IP_3 internal_ip=10.0.1.12

[consul]
consul-srv ansible_host=EXTERNAL_IP_4 internal_ip=10.0.1.20

[haproxy]
haproxy ansible_host=EXTERNAL_IP_5 internal_ip=10.0.1.30

[observer]
observer ansible_host=EXTERNAL_IP_6 internal_ip=10.0.1.40

[all:vars]
ansible_user=deploy
ansible_ssh_private_key_file=~/.ssh/id_rsa
ansible_ssh_common_args='-o StrictHostKeyChecking=no'
