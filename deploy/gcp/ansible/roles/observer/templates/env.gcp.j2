# Generated by Ansible — tool/ configuration for GCP cluster
# Copy to .env before running: cp .env.gcp .env

# Patroni REST API endpoints (one per node)
PATRONI_TARGETS={% for host in groups['patroni'] %}{{ host }}:http://{{ hostvars[host]['internal_ip'] }}:8008{% if not loop.last %},{% endif %}{% endfor %}


# Consul server HTTP API
CONSUL_URL=http://{{ consul_server_ip }}:8500

# PostgreSQL direct connections (for postgres observer)
PG_TARGETS={% for host in groups['patroni'] %}{{ host }}:host={{ hostvars[host]['internal_ip'] }} port=5432 dbname=postgres user=postgres password=postgres connect_timeout=5{% if not loop.last %},{% endif %}{% endfor %}


# Client connection — through HAProxy (combo 06 equivalent)
PG_CONNSTRING=host={{ haproxy_ip }} port=5000 dbname=postgres user=postgres password=postgres connect_timeout=5

# HAProxy stats endpoint
HAPROXY_STATS_URL=http://{{ haproxy_ip }}:8404/stats

# TimescaleDB
TSDB_HOST=localhost
TSDB_PORT=5433
TSDB_USER=bench
TSDB_PASS=bench
TSDB_DB=bench

# Combination identifier for this run
COMBINATION_ID=06-haproxy-rest-polling-gcp

# Observer polling interval (ms)
POLL_INTERVAL_MS=100

# Client heartbeat interval (ms)
HEARTBEAT_INTERVAL_MS=100
