#!/bin/bash
# Patroni on_role_change callback — updates HAProxy primary_backend server
# state via the HAProxy Runtime API TCP socket.
#
# Called by Patroni as: haproxy_callback.sh <action> <role> <scope>
#
# Server name is baked in at deploy time by Ansible (inventory_hostname).
# HAProxy host IP is injected from inventory hostvars at deploy time.
# Using Python's socket module (not socat) — socat is not installed on
# Patroni nodes. Safety: never fails Patroni if HAProxy is unreachable.

ACTION=$1   # on_role_change (only callback registered)
ROLE=$2     # master, primary, replica, demoted, uninitialized
SCOPE=$3

NODE="{{ inventory_hostname }}"
HAPROXY_HOST="{{ hostvars[groups['haproxy'][0]]['internal_ip'] }}"
HAPROXY_PORT={{ haproxy_callback_port }}

if [ "$ROLE" = "primary" ] || [ "$ROLE" = "master" ]; then
    STATE="ready"
else
    STATE="maint"
fi

python3 - <<EOF 2>/dev/null || true
import socket, sys
try:
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.settimeout(5)
    s.connect(("${HAPROXY_HOST}", ${HAPROXY_PORT}))
    s.sendall(b"set server primary_backend/${NODE} state ${STATE}\n")
    s.close()
except Exception as e:
    sys.exit(0)  # never fail Patroni if HAProxy is unavailable
EOF
