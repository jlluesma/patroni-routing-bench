project_id = "your-gcp-project-id"
region     = "europe-west1"
zone       = "europe-west1-b"

# VM sizing
machine_type_patroni  = "e2-medium"   # 2 vCPU, 4 GB RAM
machine_type_consul   = "e2-small"    # 2 vCPU, 2 GB RAM
machine_type_haproxy  = "e2-small"
machine_type_observer = "e2-medium"

# Disk
boot_disk_size_gb = 20
boot_disk_type    = "pd-ssd"

# OS image
os_image = "ubuntu-os-cloud/ubuntu-2404-lts-amd64"

# Network
network_name = "prb-network"
subnet_cidr  = "10.0.1.0/24"

# Restrict external access to your IP (e.g. "203.0.113.5/32")
# Use "0.0.0.0/0" to allow all — not recommended for production
admin_cidr = "0.0.0.0/0"

# SSH
ssh_user             = "deploy"
ssh_public_key_path  = "~/.ssh/id_rsa.pub"
